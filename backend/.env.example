# Projeto Supabase "lotofacil" (sa-east-1, ref efdfggiearsnpzyjrith).
# Pegue a senha em: https://supabase.com/dashboard/project/efdfggiearsnpzyjrith/settings/database
# Usa o Session Pooler (IPv4) em vez da conexão direta (IPv6) — a rede local não
# tem rota IPv6 pra Supabase, a conexão direta dá timeout. Pegue a string exata
# em Database Settings > Connection Pooling > Session mode (o host varia por
# projeto, ex: aws-1-sa-east-1, não é sempre aws-0).
DATABASE_URL=postgresql://postgres.efdfggiearsnpzyjrith:[SUA-SENHA]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
API_HOST=0.0.0.0
API_PORT=8001
CORS_ORIGINS=http://localhost:5173
# Protege POST /api/sync (chamado pelo cron do GitHub Actions). Gere com:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=
